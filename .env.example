# Copy to .env for local development. Real key never enters the repo.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# fake = free deterministic grader (default; use for all iteration + load tests)
# real = OpenRouter vision grading + rubric generation
GRADER_BACKEND=fake

# Optional knobs (defaults shown; see server/src/Config.ts)
# PORT=3000
# DATA_DIR=./data
# OPENROUTER_MODEL=google/gemini-3-flash-preview
# OPENROUTER_FALLBACK_MODEL=openai/gpt-5-mini   # not flash-lite: see eval/results.json (injection)
# GRADER_CONCURRENCY=8
# QUEUE_CAPACITY=200
# ATTEMPT_CAP=3
# DAILY_SUBMISSION_CAP=2000
# SUBMIT_RATE_PER_MIN=30
